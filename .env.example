# Environment Configuration for Prüfen Backend

# Database
DATABASE_URL=sqlite:///./prufen.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/prufen

# JWT Secret (change in production!)
SECRET_KEY=dev-secret-key-change-in-production-use-secrets-token-hex-32

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server
PORT=8000
DEBUG=True
